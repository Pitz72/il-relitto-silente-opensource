{
  "name": "il-relitto-silente",
  "private": true,
  "version": "1.3.4",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "wait-on tcp:3000 && electron .",
    "electron:dev": "tsc -p electron/tsconfig.json && node electron/build-helper.js && concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron\"",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && node electron/build-helper.js && electron-builder --win"
  },
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "lodash.clonedeep": "^4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.relittosilente.adventure",
    "productName": "Il Relitto Silente",
    "artifactName": "IlRelittoSilente-${version}-${os}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/app-icon.png",
      "extraFiles": [
        {
          "from": "docs/giocatore/LEGGIMI.txt",
          "to": "LEGGIMI.txt"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/app-icon.png",
      "category": "public.app-category.games",
      "darkModeSupport": true,
      "hardenedRuntime": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/app-icon.png",
      "category": "Game",
      "maintainer": "Simone Pizzi",
      "extraFiles": [
        {
          "from": "docs/giocatore/LEGGIMI.txt",
          "to": "LEGGIMI.txt"
        }
      ]
    }
  }
}
